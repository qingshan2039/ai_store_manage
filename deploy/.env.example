# 复制为 deploy/.env 后按需修改。.env 含密码，**不要进 git**（已被 .gitignore 忽略）。
# 生产用 docker-compose.prod.yml；本地手动 build 用 docker-compose.yml。

# === 数据库（PostgreSQL）===
POSTGRES_DB=ai_store_manage
POSTGRES_USER=ai_store
POSTGRES_PASSWORD=改成强随机字符串_用 openssl rand -base64 24 生成

# === 公网绑定 ===
# nginx 只绑这个公网 IP 的 80/443，避开本机 Tailscale 占用的 443。
PUBLIC_IP=152.42.184.184

# === 镜像 tag ===
# CI 默认推 latest；回滚时可填某次 commit 的完整 sha。
IMAGE_TAG=latest

# === 域名与证书（Certbot 签发 HTTPS 用）===
DOMAIN=hpclaw.org
CERTBOT_EMAIL=you@example.com
